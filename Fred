"""
FRED API connector.

The FRED API is the backbone for most regime monitor indicators.
Free, well-documented, rate-limited to 120 requests/minute.

Docs: https://fred.stlouisfed.org/docs/api/fred/
"""

import os
import json
from datetime import datetime, timedelta
from typing import Optional

import httpx

from .base import BaseConnector, DataPoint, ConnectorStatus


FRED_BASE_URL = "https://api.stlouisfed.org/fred/series/observations"

# Series that report in billions (FRED returns raw millions for some)
BILLIONS_SERIES = {"RRPONTSYD", "WTREGEN"}


class FredConnector(BaseConnector):
    """Connector for the Federal Reserve Economic Data API."""

    def __init__(self, api_key: str = ""):
        super().__init__(name="fred", api_key=api_key or os.environ.get("FRED_API_KEY", ""))
        self._client: Optional[httpx.AsyncClient] = None

    async def _get_client(self) -> httpx.AsyncClient:
        if self._client is None or self._client.is_closed:
            self._client = httpx.AsyncClient(timeout=15.0)
        return self._client

    async def fetch(self, series_id: str) -> Optional[DataPoint]:
        """Fetch the most recent observation for a FRED series."""
        if not self.api_key:
            self._last_error = "FRED_API_KEY not set. Get one free at https://fred.stlouisfed.org/docs/api/api_key.html"
            return None

        try:
            client = await self._get_client()
            params = {
                "series_id": series_id,
                "api_key": self.api_key,
                "file_type": "json",
                "sort_order": "desc",
                "limit": 5,  # Get a few in case the latest is '.'
            }
            resp = await client.get(FRED_BASE_URL, params=params)
            resp.raise_for_status()
            data = resp.json()

            observations = data.get("observations", [])
            # FRED uses '.' for missing/not-yet-released values
            for obs in observations:
                if obs["value"] != ".":
                    value = float(obs["value"])
                    # Normalize to billions where appropriate
                    if series_id in BILLIONS_SERIES:
                        value = value / 1000.0  # FRED reports in millions for some
                    ts = datetime.strptime(obs["date"], "%Y-%m-%d")
                    dp = DataPoint(
                        series_id=series_id,
                        value=round(value, 4),
                        timestamp=ts,
                        source="fred",
                        raw_metadata={"observation_date": obs["date"]},
                    )
                    self._cache[series_id] = dp
                    self._last_sync = datetime.utcnow()
                    self._last_error = ""
                    return dp

            self._last_error = f"No valid observations for {series_id}"
            return None

        except httpx.HTTPStatusError as e:
            self._last_error = f"FRED API error {e.response.status_code} for {series_id}"
            return None
        except Exception as e:
            self._last_error = f"FRED fetch error: {type(e).__name__}: {e}"
            return None

    async def fetch_batch(self, series_ids: list[str]) -> list[DataPoint]:
        """Fetch multiple FRED series. Sequential to respect rate limits."""
        results = []
        for sid in series_ids:
            dp = await self.fetch(sid)
            if dp:
                results.append(dp)
        return results

    async def fetch_history(
        self, series_id: str, start_date: str = "2020-01-01", end_date: str = ""
    ) -> list[DataPoint]:
        """Fetch historical observations for backtesting."""
        if not self.api_key:
            return []

        try:
            client = await self._get_client()
            params = {
                "series_id": series_id,
                "api_key": self.api_key,
                "file_type": "json",
                "observation_start": start_date,
                "sort_order": "asc",
            }
            if end_date:
                params["observation_end"] = end_date

            resp = await client.get(FRED_BASE_URL, params=params)
            resp.raise_for_status()
            data = resp.json()

            results = []
            for obs in data.get("observations", []):
                if obs["value"] != ".":
                    value = float(obs["value"])
                    if series_id in BILLIONS_SERIES:
                        value = value / 1000.0
                    results.append(DataPoint(
                        series_id=series_id,
                        value=round(value, 4),
                        timestamp=datetime.strptime(obs["date"], "%Y-%m-%d"),
                        source="fred",
                    ))
            return results

        except Exception:
            return []

    async def test_connection(self) -> ConnectorStatus:
        """Test FRED API connectivity."""
        if not self.api_key:
            return ConnectorStatus(
                name="fred", connected=False,
                error="FRED_API_KEY not configured",
            )
        dp = await self.fetch("DGS10")
        return ConnectorStatus(
            name="fred",
            connected=dp is not None,
            last_sync=self._last_sync,
            error=self._last_error,
        )

    async def close(self):
        if self._client and not self._client.is_closed:
            await self._client.aclose()
