"""
Alpha Vantage connector.

Equity prices, ETF prices, and FX rates.
Free tier: 25 calls/day. Premium tiers available.
Docs: https://www.alphavantage.co/documentation/
"""

import os
import asyncio
from datetime import datetime
from typing import Optional

import httpx

from .base import BaseConnector, DataPoint, ConnectorStatus


AV_BASE_URL = "https://www.alphavantage.co/query"

# Rate limiting for free tier
RATE_LIMIT_CALLS_PER_MIN = 5
RATE_LIMIT_DELAY = 60.0 / RATE_LIMIT_CALLS_PER_MIN  # 12 seconds between calls


class AlphaVantageConnector(BaseConnector):
    """Connector for Alpha Vantage market data."""

    def __init__(self, api_key: str = ""):
        super().__init__(
            name="alpha_vantage",
            api_key=api_key or os.environ.get("ALPHA_VANTAGE_API_KEY", ""),
        )
        self._client: Optional[httpx.AsyncClient] = None
        self._last_call_time: float = 0

    async def _get_client(self) -> httpx.AsyncClient:
        if self._client is None or self._client.is_closed:
            self._client = httpx.AsyncClient(timeout=15.0)
        return self._client

    async def _rate_limit(self):
        """Enforce rate limiting for free tier."""
        import time
        now = time.time()
        elapsed = now - self._last_call_time
        if elapsed < RATE_LIMIT_DELAY:
            await asyncio.sleep(RATE_LIMIT_DELAY - elapsed)
        self._last_call_time = time.time()

    async def fetch(self, series_id: str) -> Optional[DataPoint]:
        """Fetch latest quote for a ticker or FX pair.

        series_id can be:
          - A stock/ETF ticker (e.g., "KRE", "HYG")
          - An FX pair (e.g., "USD/JPY")
        """
        if not self.api_key:
            self._last_error = "ALPHA_VANTAGE_API_KEY not set. Get one at https://www.alphavantage.co/support/#api-key"
            return None

        try:
            await self._rate_limit()
            client = await self._get_client()

            if "/" in series_id:
                # FX pair
                from_currency, to_currency = series_id.split("/")
                params = {
                    "function": "CURRENCY_EXCHANGE_RATE",
                    "from_currency": from_currency,
                    "to_currency": to_currency,
                    "apikey": self.api_key,
                }
                resp = await client.get(AV_BASE_URL, params=params)
                resp.raise_for_status()
                data = resp.json()

                rate_data = data.get("Realtime Currency Exchange Rate", {})
                if not rate_data:
                    self._last_error = f"No FX data for {series_id}: {data.get('Note', data.get('Information', 'Unknown'))}"
                    return None

                value = float(rate_data["5. Exchange Rate"])
                ts_str = rate_data.get("6. Last Refreshed", "")
                try:
                    ts = datetime.strptime(ts_str.split()[0], "%Y-%m-%d")
                except (ValueError, IndexError):
                    ts = datetime.utcnow()

            else:
                # Stock/ETF quote
                params = {
                    "function": "GLOBAL_QUOTE",
                    "symbol": series_id,
                    "apikey": self.api_key,
                }
                resp = await client.get(AV_BASE_URL, params=params)
                resp.raise_for_status()
                data = resp.json()

                quote = data.get("Global Quote", {})
                if not quote:
                    self._last_error = f"No quote data for {series_id}: {data.get('Note', data.get('Information', 'Unknown'))}"
                    return None

                value = float(quote.get("05. price", 0))
                ts_str = quote.get("07. latest trading day", "")
                try:
                    ts = datetime.strptime(ts_str, "%Y-%m-%d")
                except ValueError:
                    ts = datetime.utcnow()

            dp = DataPoint(
                series_id=series_id,
                value=round(value, 4),
                timestamp=ts,
                source="alpha_vantage",
                unit="$" if "/" not in series_id else "",
                raw_metadata=data,
            )
            self._cache[series_id] = dp
            self._last_sync = datetime.utcnow()
            self._last_error = ""
            return dp

        except httpx.HTTPStatusError as e:
            self._last_error = f"Alpha Vantage HTTP {e.response.status_code} for {series_id}"
            return None
        except Exception as e:
            self._last_error = f"Alpha Vantage error: {type(e).__name__}: {e}"
            return None

    async def fetch_batch(self, series_ids: list[str]) -> list[DataPoint]:
        """Fetch multiple tickers. Sequential due to rate limits."""
        results = []
        for sid in series_ids:
            dp = await self.fetch(sid)
            if dp:
                results.append(dp)
        return results

    async def test_connection(self) -> ConnectorStatus:
        """Test Alpha Vantage API connectivity."""
        if not self.api_key:
            return ConnectorStatus(
                name="alpha_vantage", connected=False,
                error="ALPHA_VANTAGE_API_KEY not configured",
            )
        dp = await self.fetch("SPY")
        return ConnectorStatus(
            name="alpha_vantage",
            connected=dp is not None,
            last_sync=self._last_sync,
            error=self._last_error,
        )

    async def close(self):
        if self._client and not self._client.is_closed:
            await self._client.aclose()
