"""
SEC EDGAR connector.

Free, public, well-structured data source. JSON API endpoints preferred
over HTML/PDF parsing per the Emerson SEC Filing Reference.

Key endpoints:
  - data.sec.gov/api/xbrl/companyfacts/ — structured financials
  - data.sec.gov/submissions/ — filing history and metadata
  - efts.sec.gov/LATEST/search-index — full-text search

Rate limit: SEC asks for max 10 requests/second, requires User-Agent header.
"""

import os
from datetime import datetime
from typing import Optional

import httpx

from .base import BaseConnector, DataPoint, ConnectorStatus


SEC_SUBMISSIONS_URL = "https://data.sec.gov/submissions/CIK{cik}.json"
SEC_COMPANYFACTS_URL = "https://data.sec.gov/api/xbrl/companyfacts/CIK{cik}.json"
SEC_FULLTEXT_URL = "https://efts.sec.gov/LATEST/search-index"
SEC_EDGAR_SEARCH = "https://efts.sec.gov/LATEST/search-index"

# SEC requires a User-Agent identifying your application
DEFAULT_USER_AGENT = "Emerson-MCP research-tool/1.0 (contact: emerson@example.com)"


class EdgarConnector(BaseConnector):
    """Connector for SEC EDGAR public filing data."""

    def __init__(self, user_agent: str = ""):
        super().__init__(name="edgar")
        self.user_agent = user_agent or os.environ.get(
            "EDGAR_USER_AGENT", DEFAULT_USER_AGENT
        )
        self._client: Optional[httpx.AsyncClient] = None

    async def _get_client(self) -> httpx.AsyncClient:
        if self._client is None or self._client.is_closed:
            self._client = httpx.AsyncClient(
                timeout=15.0,
                headers={"User-Agent": self.user_agent},
            )
        return self._client

    @staticmethod
    def _pad_cik(cik: str) -> str:
        """Pad CIK to 10 digits as required by SEC endpoints."""
        return cik.zfill(10)

    async def fetch(self, series_id: str) -> Optional[DataPoint]:
        """Not applicable for EDGAR. Use specific methods instead."""
        return None

    async def fetch_batch(self, series_ids: list[str]) -> list[DataPoint]:
        """Not applicable for EDGAR."""
        return []

    async def get_company_filings(
        self, cik: str, form_type: str = "", limit: int = 20
    ) -> dict:
        """Get recent filings for a company by CIK.

        Args:
            cik: Company CIK number (will be zero-padded)
            form_type: Filter by form type (e.g., '10-K', '8-K', 'DEF 14A')
            limit: Max filings to return

        Returns:
            Dict with company info and recent filings list
        """
        try:
            client = await self._get_client()
            padded = self._pad_cik(cik)
            url = SEC_SUBMISSIONS_URL.format(cik=padded)
            resp = await client.get(url)
            resp.raise_for_status()
            data = resp.json()

            company_name = data.get("name", "Unknown")
            tickers = data.get("tickers", [])
            recent = data.get("filings", {}).get("recent", {})

            # Build filing list
            filings = []
            forms = recent.get("form", [])
            dates = recent.get("filingDate", [])
            accessions = recent.get("accessionNumber", [])
            descriptions = recent.get("primaryDocDescription", [])

            for i in range(min(len(forms), limit * 3)):  # over-fetch then filter
                if form_type and forms[i] != form_type:
                    continue
                filings.append({
                    "form": forms[i],
                    "date": dates[i],
                    "accession": accessions[i],
                    "description": descriptions[i] if i < len(descriptions) else "",
                    "url": f"https://www.sec.gov/Archives/edgar/data/{cik}/{accessions[i].replace('-', '')}/{accessions[i]}-index.htm",
                })
                if len(filings) >= limit:
                    break

            self._last_sync = datetime.utcnow()
            self._last_error = ""
            return {
                "cik": cik,
                "company_name": company_name,
                "tickers": tickers,
                "filings": filings,
            }

        except httpx.HTTPStatusError as e:
            self._last_error = f"EDGAR HTTP {e.response.status_code} for CIK {cik}"
            return {"error": self._last_error}
        except Exception as e:
            self._last_error = f"EDGAR error: {type(e).__name__}: {e}"
            return {"error": self._last_error}

    async def get_company_facts(self, cik: str, fact_name: str = "") -> dict:
        """Get XBRL financial facts for a company.

        More reliable than parsing HTML filings for numeric data.
        Covers balance sheet, income statement, cash flow.

        Args:
            cik: Company CIK number
            fact_name: Optional specific fact (e.g., 'us-gaap/Revenues')

        Returns:
            Dict with company facts data
        """
        try:
            client = await self._get_client()
            padded = self._pad_cik(cik)
            url = SEC_COMPANYFACTS_URL.format(cik=padded)
            resp = await client.get(url)
            resp.raise_for_status()
            data = resp.json()

            if fact_name:
                # Extract specific fact
                namespace, name = fact_name.split("/") if "/" in fact_name else ("us-gaap", fact_name)
                facts = data.get("facts", {}).get(namespace, {}).get(name, {})
                units = facts.get("units", {})
                # Get the most common unit (usually USD)
                for unit_key, values in units.items():
                    # Return last N values
                    recent = sorted(values, key=lambda x: x.get("end", ""), reverse=True)[:10]
                    return {
                        "cik": cik,
                        "company": data.get("entityName", ""),
                        "fact": fact_name,
                        "unit": unit_key,
                        "values": recent,
                    }
                return {"cik": cik, "fact": fact_name, "error": "Fact not found"}

            # Return summary of available facts
            us_gaap = data.get("facts", {}).get("us-gaap", {})
            fact_names = list(us_gaap.keys())[:50]
            self._last_sync = datetime.utcnow()
            self._last_error = ""
            return {
                "cik": cik,
                "company": data.get("entityName", ""),
                "available_facts_sample": fact_names,
                "total_facts": len(us_gaap),
            }

        except httpx.HTTPStatusError as e:
            self._last_error = f"EDGAR facts HTTP {e.response.status_code} for CIK {cik}"
            return {"error": self._last_error}
        except Exception as e:
            self._last_error = f"EDGAR facts error: {type(e).__name__}: {e}"
            return {"error": self._last_error}

    async def search_filings(self, query: str, form_type: str = "", limit: int = 10) -> dict:
        """Full-text search across EDGAR filings.

        Args:
            query: Search terms (e.g., "covenant waiver", "going concern")
            form_type: Filter by form type
            limit: Max results

        Returns:
            Dict with search results
        """
        try:
            client = await self._get_client()
            params = {
                "q": query,
                "dateRange": "custom",
                "startdt": "2024-01-01",
                "enddt": datetime.utcnow().strftime("%Y-%m-%d"),
            }
            if form_type:
                params["forms"] = form_type

            # Use the EDGAR full-text search API
            resp = await client.get(
                "https://efts.sec.gov/LATEST/search-index",
                params=params,
            )
            resp.raise_for_status()
            data = resp.json()

            hits = data.get("hits", {}).get("hits", [])[:limit]
            results = []
            for hit in hits:
                src = hit.get("_source", {})
                results.append({
                    "company": src.get("display_names", [""])[0] if src.get("display_names") else "",
                    "form": src.get("form_type", ""),
                    "date": src.get("file_date", ""),
                    "description": src.get("display_description", ""),
                })

            self._last_sync = datetime.utcnow()
            self._last_error = ""
            return {"query": query, "total_hits": data.get("hits", {}).get("total", {}).get("value", 0), "results": results}

        except Exception as e:
            self._last_error = f"EDGAR search error: {type(e).__name__}: {e}"
            return {"query": query, "error": self._last_error}

    async def test_connection(self) -> ConnectorStatus:
        """Test EDGAR API connectivity."""
        try:
            client = await self._get_client()
            resp = await client.get(
                "https://data.sec.gov/submissions/CIK0000320193.json"  # Apple
            )
            resp.raise_for_status()
            self._last_sync = datetime.utcnow()
            self._last_error = ""
            return ConnectorStatus(name="edgar", connected=True, last_sync=self._last_sync)
        except Exception as e:
            self._last_error = str(e)
            return ConnectorStatus(name="edgar", connected=False, error=self._last_error)

    async def close(self):
        if self._client and not self._client.is_closed:
            await self._client.aclose()
