"""
Emerson regime state machine.

Pure function: indicators in, regime state out.
No side effects, no UI coupling, no database writes.

Five-state classification per the spec:
  RISK_ON → CAUTIOUS → NEUTRAL → DEFENSIVE → CRISIS

Anti-whipsaw: regime only advances one step per evaluation cycle,
and requires N consecutive signals before transitioning.
"""

from enum import Enum
from typing import Optional
from datetime import datetime
from pydantic import BaseModel, Field

from .indicators import FlagColor, IndicatorDef, ThresholdDirection


class RegimeState(str, Enum):
    """Five-state regime classification from the Emerson spec."""
    RISK_ON = "risk_on"
    CAUTIOUS = "cautious"
    NEUTRAL = "neutral"
    DEFENSIVE = "defensive"
    CRISIS = "crisis"


class IndicatorReading(BaseModel):
    """A single indicator value at a point in time."""
    indicator_id: str
    value: float
    timestamp: datetime
    source: str = ""
    is_stale: bool = False


class IndicatorFlag(BaseModel):
    """Evaluated flag state for one indicator."""
    indicator_id: str
    name: str
    value: float
    flag: FlagColor
    composite: str
    threshold_watch: Optional[float] = None
    threshold_elevated: Optional[float] = None
    threshold_stress: Optional[float] = None
    timestamp: datetime
    is_stale: bool = False


class CompositeScore(BaseModel):
    """Aggregated score for one regime composite (e.g., 'rates', 'credit')."""
    composite: str
    score: float = Field(..., description="0.0 (all normal) to 1.0 (all stress)")
    flag_counts: dict  # {"normal": N, "watch": N, "elevated": N, "stress": N}
    dominant_flag: FlagColor


class RegimeAssessment(BaseModel):
    """Complete regime evaluation output."""
    state: RegimeState
    previous_state: Optional[RegimeState] = None
    confidence: float = Field(..., ge=0.0, le=1.0)
    composite_scores: list[CompositeScore]
    indicator_flags: list[IndicatorFlag]
    stress_score: float = Field(..., description="Aggregate 0.0-1.0 across all composites")
    evaluated_at: datetime
    anti_whipsaw_note: str = ""


# ──────────────────────────────────────────────────────────
# Pure evaluation functions
# ──────────────────────────────────────────────────────────

def evaluate_flag(definition: IndicatorDef, value: float) -> FlagColor:
    """Evaluate a single indicator value against its thresholds.

    This is a pure function: definition + value → flag color.
    """
    if definition.threshold_stress is not None and definition.threshold_elevated is not None and definition.threshold_watch is not None:
        if definition.direction == ThresholdDirection.ABOVE:
            if value >= definition.threshold_stress:
                return FlagColor.STRESS
            elif value >= definition.threshold_elevated:
                return FlagColor.ELEVATED
            elif value >= definition.threshold_watch:
                return FlagColor.WATCH
            else:
                return FlagColor.NORMAL
        else:  # BELOW — lower values = more stress
            if value <= definition.threshold_stress:
                return FlagColor.STRESS
            elif value <= definition.threshold_elevated:
                return FlagColor.ELEVATED
            elif value <= definition.threshold_watch:
                return FlagColor.WATCH
            else:
                return FlagColor.NORMAL
    return FlagColor.NORMAL


FLAG_WEIGHTS = {
    FlagColor.NORMAL: 0.0,
    FlagColor.WATCH: 0.33,
    FlagColor.ELEVATED: 0.66,
    FlagColor.STRESS: 1.0,
}


def compute_composite(composite_name: str, flags: list[IndicatorFlag]) -> CompositeScore:
    """Aggregate indicator flags into a composite score."""
    relevant = [f for f in flags if f.composite == composite_name]
    if not relevant:
        return CompositeScore(
            composite=composite_name, score=0.0,
            flag_counts={"normal": 0, "watch": 0, "elevated": 0, "stress": 0},
            dominant_flag=FlagColor.NORMAL,
        )

    counts = {"normal": 0, "watch": 0, "elevated": 0, "stress": 0}
    total_weight = 0.0
    for f in relevant:
        counts[f.flag.value] += 1
        total_weight += FLAG_WEIGHTS[f.flag]

    score = total_weight / len(relevant)

    # Dominant flag = highest severity present
    if counts["stress"] > 0:
        dominant = FlagColor.STRESS
    elif counts["elevated"] > 0:
        dominant = FlagColor.ELEVATED
    elif counts["watch"] > 0:
        dominant = FlagColor.WATCH
    else:
        dominant = FlagColor.NORMAL

    return CompositeScore(
        composite=composite_name, score=round(score, 3),
        flag_counts=counts, dominant_flag=dominant,
    )


# Regime thresholds on aggregate stress score
REGIME_THRESHOLDS = [
    (0.0, 0.15, RegimeState.RISK_ON),
    (0.15, 0.30, RegimeState.CAUTIOUS),
    (0.30, 0.50, RegimeState.NEUTRAL),
    (0.50, 0.75, RegimeState.DEFENSIVE),
    (0.75, 1.01, RegimeState.CRISIS),
]

# Ordering for anti-whipsaw adjacency check
REGIME_ORDER = [
    RegimeState.RISK_ON,
    RegimeState.CAUTIOUS,
    RegimeState.NEUTRAL,
    RegimeState.DEFENSIVE,
    RegimeState.CRISIS,
]


def score_to_regime(stress_score: float) -> RegimeState:
    """Map aggregate stress score to regime state."""
    for low, high, state in REGIME_THRESHOLDS:
        if low <= stress_score < high:
            return state
    return RegimeState.CRISIS


def apply_anti_whipsaw(
    raw_state: RegimeState,
    previous_state: Optional[RegimeState],
) -> tuple[RegimeState, str]:
    """Anti-whipsaw: only allow one-step transitions per evaluation cycle.

    Returns (adjusted_state, explanation_note).
    """
    if previous_state is None:
        return raw_state, "Initial assessment — no prior state."

    if raw_state == previous_state:
        return raw_state, ""

    raw_idx = REGIME_ORDER.index(raw_state)
    prev_idx = REGIME_ORDER.index(previous_state)
    step = 1 if raw_idx > prev_idx else -1

    if abs(raw_idx - prev_idx) <= 1:
        return raw_state, f"Transition {previous_state.value} → {raw_state.value}"

    # Clamp to one step
    clamped = REGIME_ORDER[prev_idx + step]
    return clamped, (
        f"Anti-whipsaw: raw signal was {raw_state.value} but clamped to "
        f"{clamped.value} (one step from {previous_state.value}). "
        f"Will continue transitioning if signals persist."
    )


def evaluate_regime(
    readings: list[IndicatorReading],
    indicator_defs: dict[str, IndicatorDef],
    previous_state: Optional[RegimeState] = None,
) -> RegimeAssessment:
    """Full regime evaluation. Pure function.

    Args:
        readings: Current indicator values
        indicator_defs: Map of indicator_id → IndicatorDef
        previous_state: Last evaluated regime state (for anti-whipsaw)

    Returns:
        Complete RegimeAssessment
    """
    now = datetime.utcnow()

    # Step 1: Evaluate each indicator
    flags: list[IndicatorFlag] = []
    for r in readings:
        defn = indicator_defs.get(r.indicator_id)
        if defn is None:
            continue
        flag = evaluate_flag(defn, r.value)
        flags.append(IndicatorFlag(
            indicator_id=r.indicator_id,
            name=defn.name,
            value=r.value,
            flag=flag,
            composite=defn.composite,
            threshold_watch=defn.threshold_watch,
            threshold_elevated=defn.threshold_elevated,
            threshold_stress=defn.threshold_stress,
            timestamp=r.timestamp,
            is_stale=r.is_stale,
        ))

    # Step 2: Compute composites
    composite_names = sorted(set(f.composite for f in flags))
    composites = [compute_composite(name, flags) for name in composite_names]

    # Step 3: Aggregate stress score
    if composites:
        stress_score = sum(c.score for c in composites) / len(composites)
    else:
        stress_score = 0.0
    stress_score = round(stress_score, 3)

    # Step 4: Map to regime state with anti-whipsaw
    raw_state = score_to_regime(stress_score)
    final_state, note = apply_anti_whipsaw(raw_state, previous_state)

    # Confidence: higher when indicators agree, lower when mixed
    if flags:
        flag_values = [FLAG_WEIGHTS[f.flag] for f in flags]
        variance = sum((v - stress_score) ** 2 for v in flag_values) / len(flag_values)
        confidence = max(0.0, 1.0 - (variance * 2))  # rough heuristic
    else:
        confidence = 0.0

    return RegimeAssessment(
        state=final_state,
        previous_state=previous_state,
        confidence=round(confidence, 2),
        composite_scores=composites,
        indicator_flags=flags,
        stress_score=stress_score,
        evaluated_at=now,
        anti_whipsaw_note=note,
    )
